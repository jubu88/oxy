{
  "name": "oxy",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Build web apps with a local LLM. Simple, beautiful, just works.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "node --test agent/loop.test.ts agent/tools.test.ts engine/tool-parse.test.ts engine/openai-map.test.ts skillopt/score.test.ts skillopt/loop.test.ts skillopt/supervisor.test.ts server/sandbox.test.mjs server/auto-promote.test.mjs",
    "oxy": "node driver/run-build.ts",
    "serve": "node server/serve.mjs",
    "skillopt": "node skillopt/optimize.ts",
    "skillopt:ab": "node skillopt/ab.ts",
    "skillopt:promote": "node skillopt/promote.ts",
    "setup-sd": "node scripts/setup-sd.mjs",
    "test:sandbox-canary": "node --test server/sandbox.canary.test.mjs"
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "typescript": "^5",
    "vite": "^6"
  },
  "optionalDependencies": {
    "playwright": "^1"
  }
}
